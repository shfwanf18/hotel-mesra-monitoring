# ──────────────────────────────────────────────
# Mesra Network Monitoring — Environment Config
# Salin file ini menjadi .env dan sesuaikan nilai-nilainya
# ──────────────────────────────────────────────

# ── Database PostgreSQL ──────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=wawan
DB_DATABASE=mesra_monitoring

# ── Email Alert ──────────────────────────────
# Gunakan App Password Gmail (bukan password biasa)
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password
MAIL_TO=alert_recipient@gmail.com

# ── Frontend API URL ─────────────────────────
# URL backend yang diakses oleh browser (bukan Docker internal network)
# Jika deploy di server: ganti dengan IP/domain server Anda
# Contoh: http://192.168.1.100:3000 atau http://monitoring.hotel.local:3000
VITE_API_URL=http://localhost:3000
